if [[ $(id -u) -ne 0 ]]; then
  echo "Please run as root"
  exit 1
fi

# Decrypt the bootstrap token, asking the password to the sys admin
# --setup checks for SETUP_CONSUL_TOKEN env variable and uses it
# to avoid re-asking for the password
echo -n "Insert the cluster credential password: "
export SETUP_CONSUL_TOKEN=$(service-discover bootstrap-token --setup)
EXIT_CODE="$?"
echo ""
if [[ "${EXIT_CODE}" != "0" ]]; then
  echo "Cannot access to bootstrap token"
  exit 1;
fi

# Standard setup via quarkus-extensions (policy, token, KV migration, systemd override)
/usr/share/carbonio/carbonio-docs-connector-ce-runner \
  --setup http://127.0.0.1:8500
SETUP_EXIT_CODE="$?"

# Do not mark the pending-setup as done (and do not restart) if --setup failed.
if [[ "${SETUP_EXIT_CODE}" != "0" ]]; then
  # Limit secret visibility as much as possible
  export -n SETUP_CONSUL_TOKEN
  echo "Setup failed (exit ${SETUP_EXIT_CODE}); leaving pending-setup to be retried."
  exit "${SETUP_EXIT_CODE}"
fi

# Reload the consul agent with the bootstrap token (consul CLI reads CONSUL_HTTP_TOKEN,
# not SETUP_CONSUL_TOKEN) before dropping the token from the environment.
CONSUL_HTTP_TOKEN="${SETUP_CONSUL_TOKEN}" consul reload

# Limit secret visibility as much as possible
export -n SETUP_CONSUL_TOKEN

systemctl restart carbonio-docs-connector.service
systemctl restart carbonio-docs-connector-sidecar.service
