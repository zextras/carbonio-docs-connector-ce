  "carbonio-docs-connector.hcl"
  "carbonio-docs-connector.jar"
  "carbonio-docs-connector.service"
  "carbonio-docs-connector-setup"
  "carbonio-docs-connector-sidecar.service"
  "carbonio-docs-connector-pending-setup"
  "intentions.json"
  "policies.json"
  "service-protocol.json"
)
