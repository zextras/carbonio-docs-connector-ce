_package_common() {
  install -Dm755 "${srcdir}/carbonio-docs-connector" \
    "${pkgdir}/usr/bin/carbonio-docs-connector"

  install -Dm755 "${srcdir}/carbonio-docs-connector-setup" \
    "${pkgdir}/usr/bin/carbonio-docs-connector-setup"

  install -Dm755 "${srcdir}/carbonio-docs-connector-ce-runner" \
    "${pkgdir}/usr/share/carbonio/carbonio-docs-connector-ce-runner"

  install -Dm644 "${srcdir}/carbonio-docs-connector.service" \
    "${pkgdir}/lib/systemd/system/carbonio-docs-connector.service"

  install -Dm644 "${srcdir}/carbonio-docs-connector.hcl" \
    "${pkgdir}/etc/zextras/service-discover/carbonio-docs-connector.hcl"

  install -Dm644 "${srcdir}/521-carbonio-docs-connector.sh" \
    "${pkgdir}/etc/zextras/pending-setups.d/521-carbonio-docs-connector.sh"

  install -Dm644 "${srcdir}/intentions.json" \
    "${pkgdir}/etc/carbonio/docs-connector/service-discover/intentions.json"

  install -Dm644 "${srcdir}/policies.json" \
    "${pkgdir}/etc/carbonio/docs-connector/service-discover/policies.json"

  install -Dm644 "${srcdir}/service-protocol.json" \
    "${pkgdir}/etc/carbonio/docs-connector/service-discover/service-protocol.json"
}

_package_systemd() {
  _package_common
  install -Dm644 "${srcdir}/carbonio-docs-connector-sidecar.service" \
    "${pkgdir}/lib/systemd/system/carbonio-docs-connector-sidecar.service"
}

_package_legacy() {
  _package_common
  install -Dm644 "${srcdir}/carbonio-docs-connector-sidecar-legacy.service" \
    "${pkgdir}/lib/systemd/system/carbonio-docs-connector-sidecar.service"
}

package() { _package_systemd; }
package__rocky_8() { _package_legacy; }
package__ubuntu_jammy() { _package_legacy; }

postinst() {
  getent group 'carbonio-docs-connector' >/dev/null \
    || groupadd -r 'carbonio-docs-connector'
  getent passwd 'carbonio-docs-connector' >/dev/null \
    || useradd -r -M -g 'carbonio-docs-connector' -s /sbin/nologin 'carbonio-docs-connector'

  mkdir -p "/var/log/carbonio/docs-connector/"
  chown carbonio-docs-connector:carbonio-docs-connector "/var/log/carbonio/docs-connector"

  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
    systemctl enable carbonio-docs-connector.service >/dev/null 2>&1 || :
    systemctl enable carbonio-docs-connector-sidecar.service >/dev/null 2>&1 || :
  fi

  echo "======================================================"
  echo "Carbonio Docs Connector installed successfully!       "
  echo "You must run pending-setups to configure it correctly."
  echo "======================================================"
}

prerm() {
  if [ -d /run/systemd/system ]; then
    systemctl --no-reload disable carbonio-docs-connector.service >/dev/null 2>&1 || :
    systemctl --no-reload disable carbonio-docs-connector-sidecar.service >/dev/null 2>&1 || :
    systemctl stop carbonio-docs-connector.service >/dev/null 2>&1 || :
    systemctl stop carbonio-docs-connector-sidecar.service >/dev/null 2>&1 || :
  fi
}

postrm() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
  fi
}
