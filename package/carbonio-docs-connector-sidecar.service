[Unit]
Description=Carbonio Docs Connector Sidecar
Documentation=https://docs.zextras.com/
Requires=network-online.target
After=network-online.target service-discover.service
PartOf=service-discover.target

[Service]
User=carbonio-docs-connector
Type=notify
NotifyAccess=all
ExecStart=/usr/bin/service-discover-wrapper.sh \
    -token-file /etc/carbonio/docs-connector/service-discover/token \
    -admin-bind localhost:0 \
    -sidecar-for carbonio-docs-connector
ExecReload=/usr/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=15s
KillSignal=SIGINT
LimitNOFILE=65536

# Hardening
PrivateTmp=yes
ProtectSystem=yes
NoNewPrivileges=yes
PrivateDevices=yes
ProtectHome=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictRealtime=yes
RestrictNamespaces=yes
RestrictSUIDSGID=yes
LockPersonality=yes
ProtectHostname=yes
ProtectClock=yes
MemoryDenyWriteExecute=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

[Install]
WantedBy=service-discover.target
